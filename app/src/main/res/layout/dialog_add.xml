<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <!-- Tên tài liệu -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên tài liệu"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editDocumentName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Nhập tên tài liệu"
        android:background="@drawable/edittext_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- Đường dẫn -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đường dẫn file"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/txtPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chưa chọn file"
        android:textColor="#666666"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>
    <Button android:id="@+id/btnChooseFile" android:layout_width="match_parent" android:layout_height="48dp" android:text="Chọn file" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:layout_marginBottom="16dp"/>

    <!-- ⭐ THÊM PHẦN LOẠI TỆP NGAY DƯỚI ĐƯỜNG DẪN -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loại tệp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editFileType"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="VD: PDF, DOCX, PNG..."
        android:background="@drawable/edittext_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="24dp"/>
    <!-- ⭐ END -->


    <!-- Môn học -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Môn học"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

<!--    <Spinner-->
<!--        android:id="@+id/spinnerSubject"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="48dp"-->
<!--        android:background="@drawable/spinner_background"-->
<!--        android:layout_marginBottom="24dp"/>-->
    <AutoCompleteTextView
        android:id="@+id/autoCompleteSubject"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:hint="Nhập môn học"
        android:inputType="text" />

    <!-- Nút Lưu -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Lưu"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"/>
</LinearLayout>
