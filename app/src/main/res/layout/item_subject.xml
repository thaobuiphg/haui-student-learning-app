<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Tên môn học -->
        <TextView
            android:id="@+id/tvSubjectName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đại số tuyến tính"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <!-- 3 nút tròn: Nhập điểm (+) | Sửa (bút chì) | Xóa (thùng rác) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <!-- Nút 1: Nhập điểm (+) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddScore"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp"
                app:iconTint="#0066CC"
                app:backgroundTint="#E3F2FD" />

            <!-- Nút 2: Sửa điểm (bút chì) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditScore"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                app:icon="@drawable/ic_edit_pencil"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp"
                app:iconTint="#7B1FA2"
                app:backgroundTint="#F3E5F5" />

            <!-- Nút 3: Xóa môn (thùng rác) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteSubject"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:icon="@drawable/ic_delete_trash"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp"
                app:iconTint="#D32F2F"
                app:backgroundTint="#FFEBEE" />
        </LinearLayout>

        <!-- Dòng điểm TX1 - TX2 - CK - TBM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tvTX1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="9.0" />

            <TextView
                android:id="@+id/tvTX2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="10.0" />

            <TextView
                android:id="@+id/tvCK"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="9.0" />

            <TextView
                android:id="@+id/tvTBM"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="9.3"
                android:textStyle="bold"
                android:textColor="#6200EE" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>